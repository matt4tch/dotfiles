# tmux aliases
ta() {
  if [ -n "$1" ]; then
    tmux attach -t "$1"
  else
    tmux attach -t "$(tmux list-sessions -F '#S' 2>/dev/null | head -n 1)"
  fi
}
alias tls='tmux list-sessions 2>/dev/null || echo "No tmux sessions"'
tns() {
  if [ -n "$1" ]; then
    tmux new -s "$1"
  else
    tmux new
  fi
}
tks() {
  if [[ -z $1 ]]; then
    tmux kill-session
  else
    tmux kill-session -t "$1"
  fi 2>/dev/null || echo "No such tmux session"
}

# typst aliases
alias tc='typst compile'

# Zsh line key bindings
bindkey '^J' backward-kill-line
bindkey -v # Enables vim mode
bindkey -M viins '^R' fzf-history-widget
